vrrp_script chk_haproxy {
    script "pidof haproxy"
    interval 2
    weight 2
}

vrrp_instance VI_1 {
    state {{ 'MASTER' if inventory_hostname == groups['load_balancers'][0] else 'BACKUP' }}
    interface {{ interface }}
    virtual_router_id {{ router_id }}
    priority {{ 200 if inventory_hostname == groups['load_balancers'][0] else 100 }}
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass 42pass
    }

    virtual_ipaddress {
        {{ vip_address }}
    }

    track_script {
        chk_haproxy
    }
}